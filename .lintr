linters: linters_with_defaults(
    line_length_linter = line_length_linter(100),
    object_name_linter = object_name_linter(
      styles = c("snake_case", "CamelCase", "SNAKE_CASE")
    ),
    indentation_linter = NULL,  # Disabled - styler handles formatting
    trailing_whitespace_linter = trailing_whitespace_linter(),
    trailing_blank_lines_linter = trailing_blank_lines_linter(),
    assignment_linter = assignment_linter(),
    brace_linter = brace_linter(allow_single_line = TRUE),
    commas_linter = commas_linter(),
    commented_code_linter = commented_code_linter(),
    cyclocomp_linter = cyclocomp_linter(complexity_limit = 20),
    object_usage_linter = object_usage_linter(
      interpret_extensions = "glue",
      skip_with = TRUE
    ),
    object_length_linter = object_length_linter(length = 35L),
    # Added from quality audit (2026-03-24) — catch real bugs
    object_overwrite_linter = object_overwrite_linter(),
    unnecessary_concatenation_linter = unnecessary_concatenation_linter(),
    unreachable_code_linter = unreachable_code_linter(),
    vector_logic_linter = vector_logic_linter(),
    missing_argument_linter = missing_argument_linter(),
    duplicate_argument_linter = duplicate_argument_linter(),
    equals_na_linter = equals_na_linter(),
    seq_linter = seq_linter(),
    lengths_linter = lengths_linter(),
    # Numerical code linters (from web research)
    matrix_apply_linter = matrix_apply_linter(),
    length_test_linter = length_test_linter(),
    scalar_in_linter = scalar_in_linter(),
    any_duplicated_linter = any_duplicated_linter(),
    any_is_na_linter = any_is_na_linter()
  )
exclusions: list(
    "R/RcppExports.R",
    "tests/testthat.R",
    "tests/testthat/helper-*.R",
    "renv.lock",
    "README.html"
  )
